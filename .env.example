# Job Search Agent — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.

# Google AI Studio — free tier key (1,500 requests/day)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Gmail sender address
GMAIL_ADDRESS=

# 16-character Google App Password (NOT your account password)
# Google Account → Security → 2-Step Verification → App Passwords
GMAIL_APP_PASSWORD=

# Recipient address for the daily digest (can be same as GMAIL_ADDRESS)
DIGEST_EMAIL=

# Minimum fit score (1-10) to include a job in the digest. Default: 6
SCORE_THRESHOLD=6

# Path to the SQLite database file.
# Local development: data/jobs.db  (gitignored)
# GitHub Actions:    data/demo.db  (set in workflow env block)
# Codespaces:        data/demo.db  (set in devcontainer.json remoteEnv)
DB_PATH=data/jobs.db
